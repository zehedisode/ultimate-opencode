{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/gpt-5.1-codex",
  "autoupdate": true,
  "lsp": true,
  "formatter": true,
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "provider": {
    "opencode": {
      "models": {
        "gpt-5.1-codex": {
          "options": {
            "reasoningEffort": "xhigh",
            "textVerbosity": "low"
          }
        }
      }
    }
  },
  "mcp": {
    "codegraph": {
      "type": "local",
      "command": ["codegraph", "serve", "--mcp"],
      "enabled": true
    },
    "codebase-memory-mcp": {
      "enabled": true,
      "type": "local",
      "command": ["codebase-memory-mcp"]
    },
    "context7": {
      "enabled": true,
      "type": "local",
      "command": ["context7-mcp"]
    },
    "filesystem": {
      "enabled": true,
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "{env:HOME}"]
    },
    "brave-search": {
      "enabled": false,
      "type": "local",
      "command": ["npx", "-y", "@brave/brave-search-mcp-server"]
    },
    "chrome-devtools": {
      "enabled": false,
      "type": "local",
      "command": ["npx", "-y", "@anthropic/chrome-devtools-mcp"]
    }
  },
  "scripts": {
    "chamber": "~/.config/opencode/scripts/chamber.sh",
    "echo": "~/.config/opencode/scripts/echo.sh",
    "prism": "~/.config/opencode/scripts/prism.sh"
  }
}
